import { breedOptions, getBreedById, readCats } from "./utility.js";
import cats from './cats.js';


export function renderEditView(id, editView) {
 
    
    const cat = readCats().find(c => c.id === id);
 
    editView = editView
        .replace('{{catName}}', cat.name)
        .replace('{{description}}', cat.description)
        .replace('{{imageUrl}}', cat.imageUrl)
        .replace('{{breedOptions}}', breedOptions(cat.breed));

        return editView
}

 
